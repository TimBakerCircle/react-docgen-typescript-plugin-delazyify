{
  "name": "react-docgen-typescript-plugin-delazyify",
  "version": "2.0.2",
  "description": "A webpack plugin to inject React TypeScript docgen information without deprecated cache dependencies.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/TimBakerCircle/react-docgen-typescript-plugin-delazyify.git"
  },
  "author": "Tim Baker <noreply@noreply>",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "react",
    "docgen",
    "typescript",
    "webpack",
    "plugin"
  ],
  "dependencies": {
    "react-docgen-typescript": "^2.4.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.7",
    "react": "^19.2.3",
    "ts-loader": "^9.5.4",
    "typescript": "6.0.3",
    "vitest": "^4.0.16",
    "webpack": "^5.104.1"
  },
  "peerDependencies": {
    "typescript": ">=5",
    "webpack": ">=5"
  }
}
